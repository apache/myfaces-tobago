{
  "name": "tobago-theme",
  "version": "6.12.0-SNAPSHOT",
  "description": "The themes of the Tobago framework",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apache/myfaces-tobago.git"
  },
  "keywords": [
    "jsf",
    "apache",
    "java",
    "myfaces",
    "css",
    "sass",
    "typescript",
    "responsive",
    "front-end",
    "framework",
    "html",
    "web",
    "bootstrap",
    "theme"
  ],
  "author": "The MyFaces Team",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://issues.apache.org/jira/projects/TOBAGO/"
  },
  "homepage": "https://myfaces.apache.org/tobago/",
  "scripts": {
    "build": "npm-run-all --parallel faces-js ts css bi",
    "css": "npm-run-all css-compile css-postprocess",
    "css-compile": "npm-run-all --parallel css-compile-*",
    "css-compile-standard": "sass --no-charset --no-error-css --load-path=./ tobago-theme-standard/src/main/scss/tobago-theme.scss:tobago-theme-standard/src/main/css/tobago.css",
    "css-compile-speyside": "sass --no-charset --no-error-css --load-path=./ tobago-theme-speyside/src/main/scss/tobago-theme.scss:tobago-theme-speyside/src/main/css/tobago.css",
    "css-compile-scarborough": "sass --no-charset --no-error-css --load-path=./ tobago-theme-scarborough/src/main/scss/tobago-theme.scss:tobago-theme-scarborough/src/main/css/tobago.css",
    "css-compile-roxborough": "sass --no-charset --no-error-css --load-path=./ tobago-theme-roxborough/src/main/scss/tobago-theme.scss:tobago-theme-roxborough/src/main/css/tobago.css",
    "css-compile-charlotteville": "sass --no-charset --no-error-css --load-path=./ tobago-theme-charlotteville/src/main/scss/tobago-theme.scss:tobago-theme-charlotteville/src/main/css/tobago.css",
    "css-postprocess": "npm-run-all --parallel css-postprocess-*",
    "css-postprocess-standard": "node lightningcss.js tobago-theme-standard/src/main/css",
    "css-postprocess-speyside": "node lightningcss.js tobago-theme-speyside/src/main/css",
    "css-postprocess-scarborough": "node lightningcss.js tobago-theme-scarborough/src/main/css",
    "css-postprocess-roxborough": "node lightningcss.js tobago-theme-roxborough/src/main/css",
    "css-postprocess-charlotteville": "node lightningcss.js tobago-theme-charlotteville/src/main/css",
    "bi": "npm-run-all --parallel bi-css bi-fonts",
    "bi-css": "ncp node_modules/bootstrap-icons/font/bootstrap-icons.css tobago-theme-standard/src/main/css/bootstrap-icons.css",
    "bi-fonts": "ncp node_modules/bootstrap-icons/font/fonts tobago-theme-standard/src/main/css/fonts",
    "faces-js": "node copy-faces-js.js",
    "ts": "npm-run-all ts-lint ts-check ts-test ts-bundle",
    "ts-lint": "eslint tobago-theme-standard/src/main/ts/*.ts",
    "ts-check": "tsc --noEmit",
    "ts-test": "jest",
    "ts-bundle": "esbuild tobago-theme-standard/src/main/ts/tobago-init.ts --bundle --sourcemap --minify --outfile=tobago-theme-standard/src/main/js/tobago.js",
    "update-check": "npx npm-check-updates",
    "update-execute": "npx npm-check-updates -u",
    "dev": "npm-run-all dev-css dev-ts",
    "dev-css": "npm-run-all css dev-css-cp",
    "dev-css-cp": "npm-run-all --parallel dev-css-cp-*",
    "dev-css-cp-standard": "ncp tobago-theme-standard/src/main/css ../tobago-example/tobago-example-demo/target/tobago-theme-standard/META-INF/resources/tobago/standard/${npm_package_version}/css",
    "dev-css-cp-charlotteville": "ncp tobago-theme-charlotteville/src/main/css ../tobago-example/tobago-example-demo/target/tobago-theme-charlotteville/META-INF/resources/tobago/charlotteville/${npm_package_version}/css",
    "dev-ts": "npm-run-all ts-bundle dev-ts-cp",
    "dev-ts-cp": "ncp tobago-theme-standard/src/main/js ../tobago-example/tobago-example-demo/target/tobago-theme-standard/META-INF/resources/tobago/standard/${npm_package_version}/js"
  },
  "dependencies": {
    "@trevoreyre/autocomplete-js": "3.0.3",
    "bootstrap": "5.3.8",
    "bootstrap-icons": "1.13.1",
    "jsf.js_next_gen": "4.1.0-beta.21",
    "lit-html": "3.3.3",
    "tabbable": "^6.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/bootstrap": "^5.2.11",
    "@types/jest": "^30.0.0",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lightningcss-cli": "^1.32.0",
    "ncp": "^2.0.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.101.0",
    "ts-jest": "^29.4.11",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
